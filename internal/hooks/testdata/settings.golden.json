{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "/usr/bin/notify-coordinator",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "/usr/bin/lint-noise write",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Write|Edit"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "/usr/bin/watch-inbox",
            "type": "command"
          },
          {
            "command": "/usr/bin/replenish",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ]
  }
}
